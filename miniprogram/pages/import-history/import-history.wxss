/* pages/import-history/import-history.wxss —— 仅页面特有样式；颜色走 app.wxss 的 var(--x) */

.ih {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ============ 时间筛选 ============ */
.ih-filter {
  background: var(--card);
  padding: 20rpx 32rpx;
  border-bottom: 2rpx solid var(--line);
}
.ih-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.ih-quick__tab {
  padding: 10rpx 28rpx;
  background: #f2f4f7;
  border-radius: var(--r-pill);
  font-size: 26rpx;
  color: var(--text-2);
}
.ih-quick__tab--on {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.ih-custom {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}
.ih-custom__label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-3);
}
.ih-custom__value {
  min-width: 150rpx;
  background: var(--bg);
  padding: 10rpx 18rpx;
  border-radius: var(--r-inner);
  font-size: 24rpx;
  color: var(--text);
  text-align: center;
}
.ih-custom__apply {
  flex-shrink: 0;
  margin-left: auto;
  padding: 10rpx 28rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--r-pill);
}

/* ============ 列表 ============ */
.ih-content {
  padding: 24rpx 32rpx;
}
.ih-loading {
  text-align: center;
  color: var(--text-3);
  font-size: 26rpx;
  padding: 80rpx 0;
}
.ih-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.ih-empty__emoji {
  font-size: 96rpx;
}
.ih-empty__text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-3);
}

.ih-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
/* 任务卡：左侧状态色条 */
.ih-card {
  background: var(--card);
  border-radius: var(--r-card);
  padding: 24rpx;
  border-left: 6rpx solid var(--line);
  box-shadow: var(--shadow);
}
.ih-card--running { border-left-color: #1989fa; }
.ih-card--done { border-left-color: #07c160; }
.ih-card--failed { border-left-color: #ee0a24; }
.ih-card--pending { border-left-color: #ff976a; }

.ih-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.ih-card__name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ih-card__status {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.ih-card__status--pending { color: #ff976a; background: #fff3e0; }
.ih-card__status--running { color: #1989fa; background: #e3f2fd; }
.ih-card__status--done { color: #07c160; background: #e8f5e9; }
.ih-card__status--failed { color: #ee0a24; background: #fce4ec; }

/* 进度条 */
.ih-progress {
  margin-bottom: 14rpx;
}
.ih-progress__info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--text-2);
  margin-bottom: 8rpx;
}
.ih-progress__word {
  color: #1989fa;
  font-weight: 500;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ih-progress__track {
  height: 12rpx;
  background: var(--bg);
  border-radius: 6rpx;
  overflow: hidden;
}
.ih-progress__bar {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #1989fa, #07c160);
  transition: width 0.3s ease;
}

/* 统计 */
.ih-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}
.ih-stat {
  font-size: 24rpx;
  color: var(--text-3);
}
.ih-stat--ok { color: #07c160; }
.ih-stat--fail { color: #ee0a24; }

/* 失败词折叠 */
.ih-fail {
  margin-top: 10rpx;
}
.ih-fail__toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #ee0a24;
  margin-bottom: 8rpx;
}
.ih-fail__arrow {
  font-size: 18rpx;
}
.ih-fail__words {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.ih-fail__word {
  font-size: 22rpx;
  background: #fce4ec;
  color: #ee0a24;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.ih-card__time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-3);
  text-align: right;
}
