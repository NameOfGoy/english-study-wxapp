/* pages/tag-manage/tag-manage.wxss —— 仅页面特有样式；颜色一律走 app.wxss 的 var(--x) */

.tm {
  /* 普通页（非 tab），底部给新建按钮留点呼吸 */
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 加载态 */
.tm-loading {
  text-align: center;
  color: var(--text-3);
  font-size: 26rpx;
  padding: 96rpx 0;
}

/* 段标题右侧计数 */
.tm-count {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-3);
}

/* 标签列表卡：每行一个标签 + 右侧操作 */
.tm-list {
  padding: 8rpx 28rpx;
}
.tm-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.tm-row + .tm-row {
  border-top: 2rpx solid var(--line);
}

/* 彩色胶囊（颜色由内联 style 注入） */
.tm-pill {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 26rpx;
  border-radius: var(--r-pill);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1;
  max-width: 60%;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 右侧操作区 */
.tm-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.tm-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--r-inner);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: #f2f4f7;
}
.tm-action:active {
  background: #e6e9ee;
}
.tm-action--danger {
  background: rgba(255, 90, 95, 0.1);
}
.tm-action--danger:active {
  background: rgba(255, 90, 95, 0.2);
}

/* 空态 */
.tm-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx;
}
.tm-empty__emoji {
  font-size: 80rpx;
}
.tm-empty__text {
  font-size: 26rpx;
  color: var(--text-3);
  margin: 16rpx 0 28rpx;
}
.tm-empty__btn {
  width: 280rpx;
  height: 80rpx;
  font-size: 28rpx;
}

/* 底部新建按钮 */
.tm-add-btn {
  margin-top: 32rpx;
}

/* ============ 底部抽屉弹层 ============ */
.tm-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 30, 50, 0.45);
  display: flex;
  align-items: flex-end;
}
.tm-sheet {
  width: 100%;
  background: var(--card);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: var(--shadow-lg);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  animation: tm-slide-up 0.22s ease;
}
@keyframes tm-slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.tm-sheet__header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 32rpx 16rpx;
}
.tm-sheet__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
}
.tm-sheet__close {
  position: absolute;
  right: 28rpx;
  top: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-3);
}

.tm-sheet__body {
  padding: 8rpx 32rpx;
}

/* 名称输入行 */
.tm-field {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--line);
}
.tm-field__label {
  font-size: 28rpx;
  color: var(--text-2);
  width: 90rpx;
  flex-shrink: 0;
}
.tm-field__input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}
.tm-ph {
  color: var(--text-3);
}

/* 系统标签开关行（黄色提示底，对照 H5 的虚线警示块） */
.tm-system-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 176, 32, 0.08);
  border: 2rpx dashed var(--warning);
  border-radius: var(--r-inner);
}
.tm-system-row__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.tm-system-row__sub {
  font-size: 22rpx;
  color: var(--text-2);
  margin-top: 6rpx;
}

/* 调色板 */
.tm-color {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin: 24rpx 0;
}
.tm-color__label {
  font-size: 28rpx;
  color: var(--text-2);
  width: 90rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}
.tm-color__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  flex: 1;
}
.tm-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}
.tm-dot--active {
  border-color: var(--text);
  transform: scale(1.12);
}

/* 预览 */
.tm-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 24rpx 0 8rpx;
}
.tm-preview__label {
  font-size: 28rpx;
  color: var(--text-2);
  width: 90rpx;
  flex-shrink: 0;
}

/* 底部操作按钮（取消 / 创建-保存 各占一半） */
.tm-sheet__actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 8rpx;
}
.tm-sheet__actions .btn-ghost,
.tm-sheet__actions .btn-primary {
  flex: 1;
  width: auto;
  height: 88rpx;
  font-size: 30rpx;
}
.tm-btn--disabled {
  opacity: 0.5;
}
