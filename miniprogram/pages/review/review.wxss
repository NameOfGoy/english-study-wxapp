/* review.wxss —— 仅页面特有微调，颜色一律 var(--xxx)，复用全局类 */

.rv-topbar {
  margin: 8rpx 0 20rpx;
}
.rv-round {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-2);
}

/* 主卡内部各阶段统一居中布局 */
.rv-card {
  min-height: 560rpx;
  justify-content: flex-start;
  margin-top: 20rpx;
}
.rv-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 28rpx;
  width: 100%;
}

/* 提问 / 提示文案 */
.rv-ask {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text);
}
.rv-tip-text {
  margin-top: 16rpx;
}

/* 释义/答案区块（hint + full 复用） */
.rv-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-top: 8rpx;
}
.rv-section__label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-3);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

/* 词性胶囊 */
.rv-pos {
  margin-bottom: 12rpx;
}

/* full 态音标行 */
.rv-phonetic-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
}
.rv-sound {
  height: 52rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

/* 例句轮播 */
.rv-ex {
  width: 100%;
  margin-top: 28rpx;
}
.rv-ex__head {
  margin-bottom: 12rpx;
}
.rv-ex__title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}
.rv-ex__count {
  font-size: 24rpx;
  color: var(--text-3);
}
.rv-swiper {
  width: 100%;
  height: 160rpx;
}
.rv-ex__item {
  padding: 24rpx;
  border-radius: var(--r-inner);
  background: rgba(108, 123, 240, 0.08);
  box-sizing: border-box;
  height: 100%;
}
.rv-ex__en {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.5;
}
.rv-ex__zh {
  display: block;
  font-size: 24rpx;
  color: var(--text-2);
  margin-top: 8rpx;
}
.rv-dots {
  margin-top: 16rpx;
}
.rv-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--line);
  transition: all 0.2s;
}
.rv-dot--active {
  width: 28rpx;
  border-radius: var(--r-pill);
  background: var(--mode-review);
}

/* 底部操作按钮区（提示/查看答案/判定共用纵向排布） */
.rv-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.rv-unknown {
  margin: 0;
}
