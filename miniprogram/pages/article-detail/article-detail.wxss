/* pages/article-detail/article-detail.wxss */

.ad {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.ad-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 140rpx 0;
  color: var(--text-3);
  font-size: 26rpx;
}
.ad-state__emoji {
  font-size: 96rpx;
}
.ad-state__text {
  font-size: 28rpx;
}
.ad-retry {
  margin-top: 12rpx;
  padding: 0 48rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  color: #fff;
  background: var(--primary);
  border-radius: var(--r-pill);
}
.ad-retry::after {
  border: none;
}
