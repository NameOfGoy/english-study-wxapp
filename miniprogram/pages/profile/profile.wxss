/* pages/profile/profile.wxss —— 仅页面特有微调，配色一律 var(--xxx) */

/* 顶部个人卡：主色渐变背景（沿用 .card 圆角/阴影规格，背景换渐变） */
.profile-hero {
  background: var(--primary-grad);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-lg);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  color: #fff;
}

/* 头像容器：相对定位，承载相机角标；点击换头像 */
.profile-hero__avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}
.profile-hero__avatar-wrap:active {
  opacity: 0.9;
}

/* emoji 占位头像（圆形半透明白底） */
.profile-hero__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: rgba(255, 255, 255, 0.22);
  flex-shrink: 0;
}

/* 头像右下角相机角标（提示可点击换头像） */
.profile-hero__camera {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(20, 30, 50, 0.18);
}

.profile-hero__name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}
.profile-hero__sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 10rpx;
}

/* 卡内一行三统计：白色文字 + 半透明白分隔 */
.profile-hero__stats {
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.25);
}
.profile-hero__num {
  color: #fff;
}
.profile-hero__label {
  color: rgba(255, 255, 255, 0.85);
}
.profile-hero__divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  align-self: center;
}

/* 真实头像图片：复用 __avatar 的圆形尺寸，去掉 emoji 居中样式、裁剪填充 */
.profile-hero__avatar-img {
  overflow: hidden;
  background: rgba(255, 255, 255, 0.22);
}

/* 退出登录项：复用 .list-item 结构，仅文字/图标用警示色 */
.profile-logout {
  color: var(--danger, #ff5a5f);
}

.profile-version {
  text-align: center;
  font-size: 22rpx;
  margin-top: 40rpx;
}

/* ============ 个人资料编辑层（fixed 蒙层 + 底部白卡） ============ */
.edit-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 30, 50, 0.45);
  display: flex;
  align-items: flex-end;
}

.edit-sheet {
  width: 100%;
  background: var(--card);
  border-radius: var(--r-card) var(--r-card) 0 0;
  box-shadow: var(--shadow-lg);
  /* 本页是 tab 页：自定义 tabBar(110rpx+safe-area)会盖住抽屉底部，
     在 24rpx 基础留白上再加 110rpx tabBar 高度 = 134rpx（与 wordbook .wb-sheet 同规范）。 */
  padding-bottom: calc(134rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 头部：取消 / 标题 / 保存 */
.edit-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--line);
}
.edit-sheet__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}
.edit-sheet__cancel {
  font-size: 30rpx;
  color: var(--text-2);
}
.edit-sheet__save {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
}
.edit-sheet__save.is-disabled {
  color: var(--text-3);
}

/* 表单区 */
.edit-sheet__body {
  padding: 8rpx 32rpx 24rpx;
}
.edit-field {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--line);
}
.edit-field--last {
  border-bottom: none;
}
.edit-field__label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--text-2);
}
.edit-field__input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}
.edit-field__ph {
  color: var(--text-3);
}
/* 只读字段（账号）：弱化为灰字，右对齐 */
.edit-field__readonly {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-3);
}
