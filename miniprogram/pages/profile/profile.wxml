<!-- pages/profile/profile.wxml —— 我的(tab页) 数据来自真实 service -->
<view class="page page--tab">

  <!-- 顶部个人卡：主色渐变背景 + 头像(真实/emoji回退，可点换头像) + 昵称 + 统计 -->
  <view class="profile-hero">
    <view class="row gap-24">
      <!-- 头像容器：点击换头像；右下角相机角标提示可改 -->
      <view class="profile-hero__avatar-wrap" bindtap="onTapAvatar">
        <!-- 有头像URL且未加载失败 → <image>；否则 emoji 占位 -->
        <image
          wx:if="{{profile.avatarUrl && !profile.avatarError}}"
          class="profile-hero__avatar profile-hero__avatar-img"
          src="{{profile.avatarUrl}}"
          mode="aspectFill"
          binderror="onAvatarError"
        />
        <view wx:else class="profile-hero__avatar">{{profile.avatarEmoji}}</view>
        <view class="profile-hero__camera">📷</view>
      </view>

      <view class="col flex-1">
        <text class="profile-hero__name">{{profile.nickname}} 👤</text>
        <text class="profile-hero__sub">坚持每天，词汇量稳步上涨 🔥</text>
      </view>
    </view>

    <view class="row profile-hero__stats">
      <block wx:for="{{profile.stats}}" wx:key="label">
        <view class="stat">
          <text class="stat__num profile-hero__num">{{item.value}}</text>
          <text class="stat__label profile-hero__label">{{item.label}}</text>
        </view>
        <view wx:if="{{index < profile.stats.length - 1}}" class="profile-hero__divider"></view>
      </block>
    </view>
  </view>

  <!-- 游客：登录/注册入口（游客只读浏览，引导登录后可写） -->
  <block wx:if="{{isGuest}}">
    <view class="section-title">👋 欢迎</view>
    <view class="card setup-banner" bindtap="goLoginRegister">
      <view class="setup-banner__icon">👋</view>
      <view class="col flex-1">
        <text class="setup-banner__title">登录 / 注册</text>
        <text class="setup-banner__desc text-3">当前为游客浏览，登录后可添加单词、练习并同步你的学习数据</text>
      </view>
      <text class="list-item__arrow">›</text>
    </view>
  </block>

  <!-- 一次性「设置账号密码」入口：仅微信占位账号(account 以 wx_ 开头) 显示，设置成功后消失 -->
  <block wx:if="{{needSetup}}">
    <view class="section-title">🔐 账号安全</view>
    <view class="card setup-banner" bindtap="openSetup">
      <view class="setup-banner__icon">🔐</view>
      <view class="col flex-1">
        <text class="setup-banner__title">设置账号和密码</text>
        <text class="setup-banner__desc text-3">当前账号由微信自动创建，建议设置专属账号密码（仅可设置一次，请牢记）</text>
      </view>
      <text class="list-item__arrow">›</text>
    </view>
  </block>

  <!-- 设置项分组 -->
  <view class="section-title">⚙️ 设置</view>
  <view class="card">
    <view
      class="list-item"
      wx:for="{{profile.settings}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onTapSetting"
    >
      <view class="list-item__icon">{{item.emoji}}</view>
      <text class="flex-1">{{item.text}}</text>
      <text class="list-item__arrow">›</text>
    </view>
  </view>

  <view class="profile-version text-3">单词记忆助手 · v1.0.0</view>

  <!-- 个人资料编辑层：fixed 蒙层 + 底部白卡（复用 .card / .btn-primary 规格） -->
  <view
    wx:if="{{editVisible}}"
    class="edit-mask"
    bindtap="closeEdit"
    catchtouchmove="noop"
  >
    <!-- 卡片内点击不冒泡到蒙层（避免点输入区误关） -->
    <view class="edit-sheet" catchtap="noop">
      <view class="edit-sheet__header">
        <text class="edit-sheet__cancel" bindtap="closeEdit">取消</text>
        <text class="edit-sheet__title">个人资料</text>
        <text class="edit-sheet__save {{editSaving ? 'is-disabled' : ''}}" bindtap="saveEdit">保存</text>
      </view>

      <view class="edit-sheet__body">
        <!-- 昵称 -->
        <view class="edit-field">
          <text class="edit-field__label">昵称</text>
          <input
            class="edit-field__input"
            placeholder="请输入昵称"
            placeholder-class="edit-field__ph"
            value="{{editForm.name}}"
            data-field="name"
            maxlength="20"
            bindinput="onEditInput"
          />
        </view>
        <!-- 账号（只读展示，本期不在此修改） -->
        <view class="edit-field">
          <text class="edit-field__label">账号</text>
          <text class="edit-field__readonly">{{editForm.account || '未设置'}}</text>
        </view>
        <!-- 手机号 -->
        <view class="edit-field">
          <text class="edit-field__label">手机号</text>
          <input
            class="edit-field__input"
            type="number"
            placeholder="请输入手机号"
            placeholder-class="edit-field__ph"
            value="{{editForm.phone}}"
            data-field="phone"
            maxlength="11"
            bindinput="onEditInput"
          />
        </view>
        <!-- 邮箱 -->
        <view class="edit-field edit-field--last">
          <text class="edit-field__label">邮箱</text>
          <input
            class="edit-field__input"
            placeholder="请输入邮箱"
            placeholder-class="edit-field__ph"
            value="{{editForm.email}}"
            data-field="email"
            bindinput="onEditInput"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 「设置账号密码」弹层：一次性设置自定义账号 + 新密码（占位账号专用） -->
  <view
    wx:if="{{setupVisible}}"
    class="edit-mask"
    bindtap="closeSetup"
    catchtouchmove="noop"
  >
    <view class="edit-sheet" catchtap="noop">
      <view class="edit-sheet__header">
        <text class="edit-sheet__cancel" bindtap="closeSetup">取消</text>
        <text class="edit-sheet__title">设置账号密码</text>
        <text class="edit-sheet__save {{setupSaving ? 'is-disabled' : ''}}" bindtap="saveSetup">保存</text>
      </view>

      <view class="edit-sheet__body">
        <view class="setup-tip text-3">账号密码仅可设置一次，请牢记；设置后可在其他设备用账号密码登录。</view>
        <!-- 账号 -->
        <view class="edit-field">
          <text class="edit-field__label">账号</text>
          <input
            class="edit-field__input"
            placeholder="请输入账号"
            placeholder-class="edit-field__ph"
            value="{{setupForm.account}}"
            data-field="account"
            maxlength="100"
            bindinput="onSetupInput"
          />
        </view>
        <!-- 新密码 -->
        <view class="edit-field">
          <text class="edit-field__label">新密码</text>
          <input
            class="edit-field__input"
            type="password"
            password="{{true}}"
            placeholder="8~64位，含大小写/数字/符号任意3类"
            placeholder-class="edit-field__ph"
            value="{{setupForm.password}}"
            data-field="password"
            maxlength="64"
            bindinput="onSetupInput"
          />
        </view>
        <!-- 确认密码 -->
        <view class="edit-field edit-field--last">
          <text class="edit-field__label">确认密码</text>
          <input
            class="edit-field__input"
            type="password"
            password="{{true}}"
            placeholder="再次输入新密码"
            placeholder-class="edit-field__ph"
            value="{{setupForm.confirm}}"
            data-field="confirm"
            maxlength="64"
            bindinput="onSetupInput"
          />
        </view>
      </view>
    </view>
  </view>

</view>
