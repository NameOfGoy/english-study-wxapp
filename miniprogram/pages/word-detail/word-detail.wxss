/* pages/word-detail/word-detail.wxss —— 仅页面特有样式；颜色一律走 app.wxss 的 var(--x) */

.wd {
  /* 普通页：底部给操作区留呼吸 */
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 加载 / 错误态 */
.wd-loading {
  text-align: center;
  color: var(--text-3);
  font-size: 26rpx;
  padding: 120rpx 0;
}
.wd-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.wd-error__emoji {
  font-size: 96rpx;
}
.wd-error__text {
  font-size: 28rpx;
  color: var(--text-3);
  margin: 16rpx 0 28rpx;
}
.wd-error__btn {
  width: 280rpx;
  height: 80rpx;
  font-size: 28rpx;
}

/* ============ 主词卡 ============ */
.wd-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 32rpx 36rpx;
}
.wd-hero__word {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--text);
  text-align: center;
  word-break: break-word;
}

/* 音标行 */
.wd-phonetic {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}
.wd-phonetic--center {
  justify-content: center;
}
.wd-phonetic__label {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(61, 165, 244, 0.12);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.wd-phonetic__text {
  font-size: 30rpx;
  color: var(--text-2);
}
.wd-phonetic__play {
  height: 56rpx;
  padding: 0 22rpx;
}
.wd-phonetic__play:active {
  background: rgba(61, 165, 244, 0.2);
}

/* ============ 词性卡 ============ */
.wd-pos {
  position: relative;
  overflow: hidden;
}
.wd-pos::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--primary-grad);
}
.wd-pos__head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.wd-pos__sw {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 22rpx;
  border-radius: var(--r-pill);
  background: var(--primary-grad);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}
.wd-pos__cn {
  font-size: 26rpx;
  color: var(--text-2);
}
.wd-pos__trans {
  font-size: 32rpx;
  color: var(--text);
  font-weight: 500;
  line-height: 1.5;
}

/* 子标题（变化形式 / 例句） */
.wd-sub-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-2);
  margin: 24rpx 0 14rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid var(--line);
}

/* 变化形式 */
.wd-exchange__list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.wd-exchange__item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--r-inner);
  background: rgba(61, 165, 244, 0.08);
}
.wd-exchange__label {
  font-size: 22rpx;
  color: var(--text-3);
}
.wd-exchange__value {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 例句 */
.wd-example {
  padding: 16rpx 0;
}
.wd-example + .wd-example {
  border-top: 2rpx solid var(--line);
}
.wd-example__en {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
}
.wd-example__zh {
  display: block;
  font-size: 24rpx;
  color: var(--text-2);
  margin-top: 6rpx;
}

/* 配图 */
.wd-picture {
  margin-top: 24rpx;
}
.wd-picture__img {
  width: 100%;
  height: 360rpx;
  border-radius: var(--r-inner);
  background: var(--line);
  display: block;
}

/* 配图入口（pos 卡内 / 短语图卡内） */
.wd-pic-entry {
  margin-top: 20rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-pill);
  background: rgba(61, 165, 244, 0.1);
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 500;
}
.wd-phrase-pic {
  display: flex;
  flex-direction: column;
}
.wd-phrase-pic .wd-picture {
  margin-top: 0;
}

/* 配图弹层：预览 + 来源操作 */
.wd-pic-preview {
  width: 100%;
  height: 420rpx;
  border-radius: var(--r-inner);
  overflow: hidden;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.wd-pic-preview__img {
  width: 100%;
  height: 100%;
  display: block;
}
.wd-pic-preview__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.wd-pic-preview__emoji {
  font-size: 88rpx;
}
.wd-pic-preview__tip {
  font-size: 24rpx;
  color: var(--text-3);
}
.wd-pic-sources {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.wd-pic-src {
  flex: 1;
  width: auto;
  height: 84rpx;
  font-size: 28rpx;
}
.wd-pic-restore {
  margin-top: 16rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-pill);
  background: #f2f4f7;
  color: var(--text-2);
  font-size: 26rpx;
}

/* 短语释义大块 */
.wd-phrase-trans {
  font-size: 32rpx;
  color: var(--text);
  font-weight: 500;
  line-height: 1.6;
}

/* ============ 底部操作区 ============ */
.wd-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.wd-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 0;
  background: var(--card);
  border-radius: var(--r-card);
  box-shadow: var(--shadow);
}
.wd-action:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-lg);
}
.wd-action__icon {
  font-size: 44rpx;
  line-height: 1;
}
.wd-action__label {
  font-size: 24rpx;
  color: var(--text-2);
}
.wd-action--danger .wd-action__label {
  color: var(--danger);
}

/* ============ 通用弹层（底部抽屉，复刻 tag-manage / profile 蒙层） ============ */
.wd-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(20, 30, 50, 0.45);
  display: flex;
  align-items: flex-end;
}
.wd-sheet {
  width: 100%;
  max-height: 84vh;
  display: flex;
  flex-direction: column;
  background: var(--card);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: var(--shadow-lg);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  animation: wd-slide-up 0.22s ease;
}
@keyframes wd-slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.wd-sheet__header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 32rpx 12rpx;
  flex-shrink: 0;
}
.wd-sheet__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
}
.wd-sheet__close {
  position: absolute;
  right: 28rpx;
  top: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-3);
}
.wd-sheet__word {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  padding: 4rpx 32rpx 12rpx;
  flex-shrink: 0;
}
.wd-sheet__body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 12rpx 32rpx;
  -webkit-overflow-scrolling: touch;
}
.wd-sheet__actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 8rpx;
  border-top: 2rpx solid var(--line);
  flex-shrink: 0;
}
.wd-sheet__actions .btn-ghost,
.wd-sheet__actions .btn-primary {
  flex: 1;
  width: auto;
  height: 88rpx;
  font-size: 30rpx;
}
.wd-btn--disabled {
  opacity: 0.5;
}
.wd-ph {
  color: var(--text-3);
}

/* ---- 释义编辑弹层 ---- */
.wd-trans-row {
  margin-bottom: 24rpx;
}
.wd-trans-row__pos {
  display: inline-block;
  background: rgba(61, 165, 244, 0.1);
  color: var(--primary);
  padding: 4rpx 18rpx;
  border-radius: var(--r-pill);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.wd-trans-row__input {
  width: 100%;
  min-height: 120rpx;
  box-sizing: border-box;
  background: #f7f8fa;
  border-radius: var(--r-inner);
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.5;
}
.wd-hint {
  display: block;
  color: var(--danger);
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ---- 状态编辑弹层 ---- */
.wd-status-opt {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 20rpx;
  border-radius: var(--r-inner);
  margin-bottom: 16rpx;
  background: #f7f8fa;
  border: 2rpx solid transparent;
}
.wd-status-opt--active {
  background: rgba(61, 165, 244, 0.08);
  border-color: var(--primary);
}
.wd-status-opt__radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #d4d8de;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}
.wd-status-opt--active .wd-status-opt__radio {
  border-color: var(--primary);
}
.wd-status-opt__dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}
.wd-dot--study      { background: var(--mode-study); }
.wd-dot--review     { background: var(--mode-review); }
.wd-dot--strengthen { background: var(--mode-strength); }
.wd-dot--finish     { background: var(--success); }
.wd-status-opt__label {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 500;
}

/* ---- 标签编辑弹层 ---- */
.wd-tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.wd-tag-pill {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: var(--r-pill);
  background: #f2f4f7;
  color: var(--text-2);
  font-size: 26rpx;
  line-height: 1;
}
.wd-tag-pill--on {
  color: #fff;
  font-weight: 600;
  box-shadow: var(--shadow);
}
.wd-tag-pill--new {
  background: #fff;
  color: var(--primary);
  border: 2rpx dashed var(--primary);
}
.wd-tag-empty {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-3);
  padding: 12rpx 0;
}

/* 新建标签子表单 */
.wd-create {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f7f8fa;
  border-radius: var(--r-inner);
}
.wd-create__field {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--line);
}
.wd-create__label {
  font-size: 28rpx;
  color: var(--text-2);
  width: 90rpx;
  flex-shrink: 0;
}
.wd-create__input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}
.wd-create__color {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 20rpx;
}
.wd-create__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  flex: 1;
}
.wd-dot-color {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}
.wd-dot-color--active {
  border-color: var(--text);
  transform: scale(1.12);
}
.wd-create__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.wd-create__btn {
  flex: 1;
  width: auto;
  height: 76rpx;
  font-size: 28rpx;
}
