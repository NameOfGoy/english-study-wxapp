.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  border-top: 2rpx solid #EEF1F5;
  box-shadow: 0 -6rpx 20rpx rgba(20, 30, 50, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 110rpx;
}

.tab-item__emoji {
  font-size: 40rpx;
  line-height: 1;
  transition: transform 0.18s ease;
  filter: grayscale(40%);
  opacity: 0.6;
}

.tab-item__text {
  font-size: 22rpx;
  color: #9AA3AF;
  line-height: 1;
}

.tab-item--active .tab-item__emoji {
  transform: scale(1.18) translateY(-2rpx);
  filter: none;
  opacity: 1;
}

.tab-item--active .tab-item__text {
  color: #3DA5F4;
  font-weight: 600;
}
